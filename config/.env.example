# ── Azure AD ──────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── SharePoint ─────────────────────────────────────────────────────────────────
# Full URL to your SharePoint site, no trailing slash
SHAREPOINT_SITE_URL=https://contoso.sharepoint.com/sites/mysite
# Used by Office365-REST-Python-Client
SHAREPOINT_USERNAME=admin@contoso.onmicrosoft.com
SHAREPOINT_PASSWORD=your-sp-password-here

# ── Dropbox ────────────────────────────────────────────────────────────────────
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token
# OR use a long-lived access token directly (not recommended for production)
DROPBOX_ACCESS_TOKEN=

# ── Reporting ──────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
